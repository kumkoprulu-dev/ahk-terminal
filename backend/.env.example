# Finnhub API anahtarı (https://finnhub.io). Boş bırakılırsa yfinance kullanılır.
FINNHUB_API_KEY=

# Varsayılan veri sağlayıcı: auto | yfinance | finnhub
DATA_PROVIDER=auto

# OHLCV önbellek TTL (saniye). 0 = sınırsız (gün-içi dışı için makul).
CACHE_TTL=3600

# Depolama backend: parquet (varsayılan, dosya) | sqlite (tek dosyalık DB, TimescaleDB-hazır)
STORAGE_BACKEND=parquet

# TimescaleDB/Postgres bağlantısı (ileride). Boşsa kullanılmaz.
# DATABASE_URL=postgresql://user:pass@localhost:5432/market
DATABASE_URL=
