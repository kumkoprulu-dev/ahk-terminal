# KatılımLens — LLM ayarları
# Bu dosyayı ".env" olarak kopyalayın ve kendi (ÜCRETSİZ) API anahtarınızı girin.
# Sunucu açılışta otomatik okur. .env asla git'e gönderilmez (.gitignore'da).
# UYARI: Gerçek anahtarı BU dosyaya (.env.example) DEĞİL, ".env" dosyasına yazın.

# ---- ÜCRETSİZ seçenek 1: Groq (önerilen — hızlı, kart istemez) ----
# Anahtar: https://console.groq.com/keys (ücretsiz, kartsız; gsk_ ile başlar)
TF_LLM_PROVIDER=groq
TF_OPENAI_API_KEY=buraya_groq_anahtarini_yapistir

# ---- ÜCRETSİZ seçenek 2: Google Gemini (TR kalitesi yüksek) ----
# Anahtar: https://aistudio.google.com/apikey (ücretsiz, kartsız; AIza ile başlar)
# TF_LLM_PROVIDER=gemini
# TF_OPENAI_API_KEY=buraya_gemini_anahtarini_yapistir

# ---- ÜCRETSİZ seçenek 3: OpenRouter (çok model, :free) ----
# Anahtar: https://openrouter.ai/keys
# TF_LLM_PROVIDER=openrouter
# TF_OPENAI_API_KEY=buraya_openrouter_anahtarini_yapistir

# ---- ÜCRETSİZ seçenek 4: Ollama (tamamen yerel, anahtar YOK) ----
# Kurulum: https://ollama.com  +  `ollama pull llama3.1:8b`
# TF_LLM_PROVIDER=ollama
# TF_OLLAMA_MODEL=llama3.1:8b

# Model override (opsiyonel):
# TF_OPENAI_MODEL=llama-3.3-70b-versatile
